{
  "headers": [
    {
      "source": "/rss.xml",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/rss+xml; charset=utf-8"
        },
        {
          "key": "Cache-Control",
          "value": "s-maxage=3600"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/rss.xml",
      "destination": "/rss.xml"
    }
  ]
}